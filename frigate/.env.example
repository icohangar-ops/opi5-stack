# Frigate environment variables.
# Copy this file to `.env` (which is gitignored) and fill in real values.
# Frigate substitutes {VAR} placeholders in config.yml from the environment.

# MQTT broker credentials (referenced as {FRIGATE_MQTT_USER} / {FRIGATE_MQTT_PASSWORD} in config.yml)
FRIGATE_MQTT_USER=changeme
FRIGATE_MQTT_PASSWORD=changeme

# RTSP camera password (reference as {FRIGATE_RTSP_PASSWORD} in camera input URLs)
FRIGATE_RTSP_PASSWORD=changeme
